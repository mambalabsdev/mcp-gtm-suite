{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.mambabuilt/mcp-gtm-suite",
  "description": "All eleven Mamba Labs account-intelligence tools in one MCP server: identity, firmographics, social, hiring, tech, funding, change feed, LinkedIn, and ICP. Clay-ready.",
  "version": "1.1.0",
  "repository": {
    "url": "https://github.com/mambalabsdev/mcp-gtm-suite",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@mambalabsdev/mcp-gtm-suite",
      "version": "1.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "APIFY_TOKEN",
          "description": "Apify API token from https://console.apify.com/account/integrations",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ]
}
